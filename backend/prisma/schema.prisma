generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  company   String
  email     String
  phone     String
  budget    String
  message   String
  createdAt DateTime @default(now())
}