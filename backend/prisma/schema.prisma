generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Lead {
  id        String        @id @default(uuid())
  name      String
  company   String
  email     String
  phone     String
  budget    String
  message   String
  createdAt DateTime      @default(now())
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique // 
  full_name     String
  company       String    @default("")
  document_id   String?    @unique 
  birth_date    DateTime?
  phone         String    @default("")
  password_hash String

  //Controle de acesso
  role          Role      @default(USER) 
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  address Address?

  
  @@map("Users")
}

model Address {
  id           String    @id @default(uuid())
  id_user      String    @unique
  user         User    @relation(fields: [id_user], references: [id])
  zip_code     String  @default("")   
  street       String  @default("")
  number       String  @default("")
  neighborhood String  @default("")
  city         String  @default("")
  state        String  @default("")
  complement   String  @default("")

  @@map("Addresses")
}

model VisitorLog {
  id         String   @id @default(uuid())
  username   String?  @default("Novo usuário") // O nome que ele digitou ao entrar
  ipAddress  String?
  userAgent  String?  // Aqui você extrai se é Mobile/Desktop para o ícone
  createdAt  DateTime @default(now())
}

model Project {
  id          String @id @default(uuid())
  projectName String
  category    String
  tech        String[]
  href        String
  imageUrl    String?
  createdAt    DateTime @default(now())
  updateAt    DateTime @updatedAt

  @@map("Projects")
}

enum Role{
  ADMIN
  USER
}